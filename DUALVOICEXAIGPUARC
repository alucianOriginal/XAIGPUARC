return 0
fi

#|SYCL TIMER KOPFZEILENEINTRAEGE IN GGML SYCL CPP INJIZIEREN
#|NUR WENN NOCH KEIN XAIGPUARC PROFILER MARKER VORHANDEN
if ! grep -q "XAIGPUARC_PROFILIER_PID" "$SYCL_FILE"; then
