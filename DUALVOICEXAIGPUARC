else
log "🔷PATCH 12|12 XAIGPUARC_PROFILIER_PID SYCL PROFILER MARKER BEREITS VORHANDEN UEBERSPRINGE INJEKTION"
fi

#|PROFILER SHELL SKRIPT SCHREIBEN
#|LIEST INTEL GPU AUSLASTUNG VRAM TEMPERATUR SYSFS ZES
log "🔷PATCH 12|12 SCHREIBE PROFILER HILFSSKRIPT'${PROFILER_SCRIPT}'"
mkdir -p "${BUILD_DIR}"

cat > "$PROFILER_SCRIPT" << 'PROFEOF'
#!/bin/bash
#|XAIGPUARC LEISTUNGS PROFILER HILFSSKRIPT
#|LIEST INTEL ARC DGPU METRIKEN UEBER SYSFS ZES

PROFILER_LOG="${1:-XAIGPUARC/xaigpuarc_perf.log}"
INTERVAL_SEC="${2:-2}"
MAX_SAMPLES="${3:-30}"
log_p() { printf "[XAIGPUARC_PROFILIER_PID] %s\n" "$*"; }

#|INTEL GPU SYSFS PFAD SUCHEN
INTEL_SYSFS_GPU=""
for D in /sys/class/drm/card*/device; do
VENDOR=$(cat "$D/vendor" 2>/dev/null || echo "")
if [ "$VENDOR" = "0x8086" ]; then
INTEL_SYSFS_GPU="$D"
break
fi
done

#|ZES SYSMAN AUSLASTUNG LESEN
read_gpu_util() {
if [ -n "$INTEL_SYSFS_GPU" ]; then
local UTIL_FILE="${INTEL_SYSFS_GPU}/drm/card0/gt/gt0/rcs0/busy"
[ -f "$UTIL_FILE" ] && cat "$UTIL_FILE" 2>/dev/null || echo "N/A"
else
echo "N/A"
fi
}

#|VRAM AUSLASTUNG LESEN
read_vram_used_mib() {
if [ -n "$INTEL_SYSFS_GPU" ]; then
local MEM_FILE="${INTEL_SYSFS_GPU}/mem_info_vram_used"
if [ -f "$MEM_FILE" ]; then
local RAW=$(cat "$MEM_FILE" 2>/dev/null || echo 0)
echo $(( RAW / 1024 / 1024 ))
else
echo "N/A"
fi
else
echo "N/A"
fi
}

#|TEMPERATUR LESEN UEBER HWMON
read_gpu_temp() {
for HWMON in /sys/class/hwmon/hwmon*/; do
local NAME=$(cat "${HWMON}name" 2>/dev/null || echo "")
if echo "$NAME" | grep -qi "i915\|xe\|intel"; then
local TEMP_FILE="${HWMON}temp1_input"
if [ -f "$TEMP_FILE" ]; then
local RAW=$(cat "$TEMP_FILE" 2>/dev/null || echo 0)
echo $(( RAW / 1000 ))
return
fi
fi
done
echo "N/A"
}

#|XAIGPUARC_PROFILIER_PID PROTOKOLL KOPFZEILE
{
echo "# XAIGPUARC_PROFILIER_PID LEISTUNGSPROTOKOLL $(date '+%Y-%m-%d %H:%M:%S')"
echo "# ZEITSTEMPEL | GPU_AUSLASTUNG VRAM_GENUTZT_MiB TEMP_GRAD_C"
} > "$PROFILER_LOG"

log_p "STARTE XAIGPUARC_PROFILIER_PID MESSUNG INTERVALL ${INTERVAL_SEC}s MAX PROBEN ${MAX_SAMPLES}"
log_p "PROTOKOLL: ${PROFILER_LOG}"

SAMPLE=0
while [ "$SAMPLE" -lt "$MAX_SAMPLES" ]; do
TS=$(date '+%H:%M:%S')
UTIL=$(read_gpu_util)
VRAM=$(read_vram_used_mib)
TEMP=$(read_gpu_temp)
ZEILE="${TS} | GPU:${UTIL}% | VRAM:${VRAM}MiB | TEMP:${TEMP}C"
echo "$ZEILE" >> "$PROFILER_LOG"
log_p "$ZEILE"
SAMPLE=$(( SAMPLE + 1 ))
sleep "$INTERVAL_SEC"
done

log_p "XAIGPUARC_PROFILIER_PID MESSUNG ABGESCHLOSSEN PROTOKOLL GESPEICHERT ${PROFILER_LOG}"
PROFEOF

chmod +x "$PROFILER_SCRIPT"

if [ -x "$PROFILER_SCRIPT" ]; then
success "✅PATCH 12|12 XAIGPUARC_PROFILIER_PID GESCHRIEBEN UND AUSFUEHRBAR'${PROFILER_SCRIPT}'"
else
error "❌PATCH 12|12 XAIGPUARC_PROFILIER_PID KONNTE NICHT GESCHRIEBEN WERDEN"
return 1
fi

#|PROFILER IM HINTERGRUND STARTEN WENN INFERENZ LAEUFT
#|AUTOMATISCH NACH MAX_SAMPLES BEENDET
log "🔷PATCH 12|12 AKTIVIERE HINTERGRUND PROFILER BEIM NAECHSTEN INFERENZ START"

#|WRAPPER FUNKTION FUER AUTOMATISCHEN PROFILER START
#|MUSS IN run_inference VOR DEM LLAMA-CLI AUFRUF EINGEBUNDEN WERDEN
xaigpuarc_start_profiler() {
local LOG="${PROFILER_LOG}"
local SCRIPT="${PROFILER_SCRIPT}"
if [ -x "$SCRIPT" ]; then
log "🔷PATCH 12|12 STARTE HINTERGRUND XAIGPUARC_PROFILIER_PID WIRD GESPEICHERT"
bash "$SCRIPT" "$LOG" 2 60 &
export XAIGPUARC_PROFILIER_PID=$!
log "🔷PATCH 12|12 PROFILER LAEUFT PID:${XAIGPUARC_PROFILIER_PID} LOG:${XAIGPUARC_PROFILIER_PID_LOG}"
fi
}
export -f xaigpuarc_start_profiler

#|STOPP FUNKTION FUER SAUBERES BEENDEN
xaigpuarc_stop_profiler() {
if [ -n "${XAIGPUARC_PROFILIER_PID:-}" ]; then
kill "${XAIGPUARC_PROFILIER_PID}" 2>/dev/null || true
success "✅PATCH 12|12 PROFILER GESTOPPT PID:${XAIGPUARC_PROFILIER_PID}"
