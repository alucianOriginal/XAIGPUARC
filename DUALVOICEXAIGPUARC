CAND_SIZE_MIB=$(( CAND_SIZE_BYTES / 1024 / 1024 ))

#|NUR KLEINERE BEI SICHEREM VRAM KLEINER BISHERIGES BESTES
if [ "$CAND_SIZE_MIB" -le "$SAFE_VRAM_MIB" ] && [ "$CAND_SIZE_MIB" -lt "$BEST_SIZE_MIB" ]; then
