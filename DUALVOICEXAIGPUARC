local BEST_MODEL=""
local BEST_SIZE_MIB=0

#|ALLE GGUF IM ORDNER PRUEFEN
local CANDIDATE
while IFS= read -r CANDIDATE; do
[ -f "$CANDIDATE" ] || continue
local CAND_SIZE_BYTES CAND_SIZE_MIB
