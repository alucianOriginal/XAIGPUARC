# 2.) KERN AUDIO AUFNAHME SPRACHERKENNUNG PRO BLOCK BERECHNET
# GIBT LEERE AUSGABE ZURUECK WENN KEINE AUDIO ZU TEXT VERSTANDEN WURDE
record_and_transcribe() {
    local audio_file="$AUDIO_TMP"
    local txt_file="${TXT_TMP}.txt"
 # GNA ENTRAUSCHPROZESSOR FILTERT UMGEBUNGSGERAEUSCHE AUS AUFNAHME
    arecord -d 4 -f S16_LE -r 16000 -c 1 "$AUDIO_TMP" &>/dev/null
    # VIER SEKUNDEN AUFNAHMEABSTAND 16Khz MONO
    if [[ $? -ne 0 ]]; then
        warn "⚠️ arecord fehlgeschlagen – Mikrofon verfügbar?"
        return 1
    fi

    # WHISPER TRASKRIPTION VON NPU|GNA|CPU UEBER SYCL
    ONEAPI_DEVICE_SELECTOR="level_zero:0" \
    "${BUILD_DIR}/bin/whisper-cli" \
        -m "$WHISPER_MODEL_PATH" \
        -f "$audio_file" \
        -ng 1 \
        -otxt "$TXT_TMP" \
        -ac 512 \
        --prompt "ENTER, KORREKTUR, ENDE, START, PAUSE" \
        --language de &>/dev/null

    #ERGEBNIS AUSLESEN
    if [[ -f "$txt_file" ]]; then
        local recognized
        recognized=$(cat "$txt_file" | tr '[:upper:]' '[:lower:]' | xargs)
        rm -f "$txt_file"

        if [[ -z "$recognized" ]]; then
            return 1   # KEINE STIMMAUFNAHME GEFUNDEN
        fi
        echo "$recognized"
        return 0
    else
        return 1
    fi
}

# 3.) HAUPTAUDIOSCHLEIFE
# SPEICHER TEXTBAUSTEINE VON AUDIOEINGABE UND STEUERT XAIGPUARC PER AUDIOBEFEHL ENTER/KORREKTUR/PAUSE/START/STOP
start_audio_stream_listener() {
    log "🔷 STARTE SPRACHMODELLDIKTATFUNKTIONSAUFNAHME"
    warn "⚠️ BEFEHLE '${CODEWORD_ENTER}'BEENDE SPRACHAUFNAME SENDE DIKTAT AN HAUPTSPRACHPROGRAMM '${CODEWORD_KORREKTUR}' LOESCHE SPRACHAUFNAME UND STARTE NEUE '${CODEWORD_PAUSE}' PAUSIERE SPRACHAUFNAME '${CODEWORD_START}' RAKTIVIERE SPRACHAUFNAHME '${CODEWORD_STOP}' BEENDET XAIGPUARC"

    while [[ $LISTENING -eq 1 ]]; do
        #WENN PAUSE DANN PAUSE FUER DIE PAUSE ANSCHLIESSEND FORTFAHREN
        if [[ $PAUSED -eq 1 ]]; then
            sleep 1
            continue
        fi

        #|SPRACHAUFNAHME IN KLEINEN STUECKEN STARTEN UND SPEICHERN
        local spoken
        spoken=$(record_and_transcribe)
        if [[ $? -ne 0 || -z "$spoken" ]]; then
            continue   # KEIN DIKTAT AUFGENOMMEN VERBINDUNG WEITER OFFEN
        fi

        # ---------- Befehlsauswertung ----------
        if [[ "$spoken" == *"$CODEWORD_ENTER"* ]]; then
            #ENTER FUEGT HAUPTPROMT DER SPRACHAUSGABEMODULE IN DAS HAUPTSPRACHMODELL VON XAIGPUARC ZUR AUSWERTUNG EIN
            #LOESCHT DAS CODEWORT AUS DEM DIKTATTEXTPROMPT FUER SAUBERES INJIZIEREN VON ANWEISUNGEN
            local text_part="${spoken%$CODEWORD_ENTER}"
            ACCUMULATED_PROMPT="${ACCUMULATED_PROMPT} ${text_part}"
            #RUECKKEHR ZU HAUPTEBENE SETZT FINALEN PROMPT FUER GROSSES SPRACHMODELL NACH DIKTATFUNKTION UND BEREINIGUNG DER SPRACHAUFNAHME
            FINAL_VOICE_PROMPT=$(echo "$ACCUMULATED_PROMPT" | xargs)
            success "✅ SENDE AUDIODIKTAT IN TEXTFORM BEREINIGT AN HAUPTSPRACHMODELL XAIGPUARC ZUR AUSWERTUNG DER AUFNAHME \"${FINAL_VOICE_PROMPT}\""
            break   # VERLAESST WIHLE SCHLEIFE ZUM AUFRUFER ZURUECK

        elif [[ "$spoken" == *"$CODEWORD_KORREKTUR"* ]]; then
            # KORREKTUR BISHERIGES DIKTAT LOESCHEN UND NEUES BEGINNEN
            ACCUMULATED_PROMPT=""
            warn "⚠️ STARTE NEUE AUFNAHME ALTE AUFNAME GELOESCHT"
            continue

        elif [[ "$spoken" == *"$CODEWORD_STOP"* ]]; then
            # ENDE BEENDE XAIGPUARC
            success "✅ BEENDE ✅ XAIGPUARC ✅DANKE FUER DIE NUTZUNG VON XAIGPUARC ✅ AUF WIEDERSEHEN✅"
            LISTENING=0
            exit 0

        elif [[ "$spoken" == *"$CODEWORD_PAUSE"* ]]; then
            # PAUSE AUFNAME ANHALTEN
            if [[ $PAUSED -eq 0 ]]; then
                PAUSED=1
                success "✅ SPRACHERKENNUNG PAUSIERT /// SPRICH->///START//<- FUER WIEDERAUNAHME SPRACHDIKTAT"
            fi
            continue

        elif [[ "$spoken" == *"$CODEWORD_START"* ]]; then
            # START PAUSE BEENDEN
            if [[ $PAUSED -eq 1 ]]; then
                PAUSED=0
                success "✅ PAUSE BEENDET SPRACHAUFNAHME LAUFT WIEDER"
            fi
            continue

        else
            #AUS AUDIOSPRACHDIKTAT DEUTSCH TEXT FUER PROMPT HAUPT KI MACHEN
            ACCUMULATED_PROMPT="${ACCUMULATED_PROMPT} ${spoken}"
            echo "DIKTAT IN GESPROCHENEN WORTEN AUFGENOMMEN ${spoken}"
        fi
    done
}

