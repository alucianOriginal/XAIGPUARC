warn "⚠️PATCH 11|12 KEIN MODELLE ORDNER GEFUNDEN UEBERSPRINGE VRAM WAECHTER"
return 0
fi

#|MODELL DATEI PRUEFEN
if [ ! -f "$MODEL_PATH_REF" ]; then
warn "⚠️PATCH 11|12 REFERENZMODELL NICHT GEFUNDEN'${MODEL_PATH_REF}'UEBERSPRINGE WAECHTER"
return 0
fi

#|VERFUEGBARER GESAMTGRAFIKARTENSPEICHER
local TOTAL_VRAM_MIB=0
if [ -n "${ARC_VRAM_MIB:-}" ] && [ -n "${IGPU_VRAM_MIB:-}" ]; then
