log "🔷PATCH 11|12 DUAL GPU VRAM POOL ERKANNT ${ARC_VRAM_MIB}MiB + ${IGPU_VRAM_MIB}MiB = ${TOTAL_VRAM_MIB}MiB"
elif [ -n "${ARC_VRAM_MIB:-}" ]; then
