log "🔷PATCH 12|12 PROTOKOLL ENTHAELT ${LINES} MESSUNGEN ${XAIGPUARC_PROFILIER_PID_LOG}"
fi
fi
}
export -f xaigpuarc_stop_profiler

success "✅PATCH 12|12 SYCL LEISTUNGS PROFILER VOLLSTAENDIG EINGEBAUT"
log "🔷PATCH 12|12 STARTE PROFILER MIT: xaigpuarc_start_profiler"
log "🔷PATCH 12|12 STOPPE PROFILER MIT: xaigpuarc_stop_profiler"
log "🔷PATCH 12|12 PROTOKOLL WIRD NACH INFERENZ GESPEICHERT UNTER: ${XAIGPUARC_PROFILIER_PID_LOG}"
}
