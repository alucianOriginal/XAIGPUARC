#|SYCL EVENT TIMER NACH QUEUE SUBMIT EINFUEGEN
sed -i '/#include "ggml-sycl.h"/a \

// XAIGPUARC_PROFILIER_PID LEISTUNGSMESSUNG Kopfzeileneintraege\n\
#include <chrono>\n\
static std::chrono::steady_clock::time_point xaigpuarc_t0;\n\
static uint64_t xaigpuarc_op_count = 0;\n\
