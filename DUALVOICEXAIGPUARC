log "🔷PATCH 11|12 MODELL PFAD GESETZT AUF RUECKFALL ${MODEL_PATH}"
else
error "❌PATCH 11|12 KEIN PASSENDES MODELL UNTER ${SAFE_VRAM_MIB}MiB IN'${MODELS_DIR}'GEFUNDEN"
warn "⚠️PATCH 11|12 STARTE TROTZDEM MIT ORIGINALMODELL SPEICHERUEBERLAUF MOEGLICH"
export MODEL_PATH="${MODEL_PATH_REF}"
fi

log "🔷PATCH 11|12 VRAM MODELL WAECHTER ABGESCHLOSSEN"
}

