elif [ -n "${IGPU_VRAM_MIB:-}" ]; then
TOTAL_VRAM_MIB="${IGPU_VRAM_MIB}"
log "🔷PATCH 11|12 EINZELGERAET IGPU VRAM ${TOTAL_VRAM_MIB}MiB"
else
#|KEIN VRAM BEKANNT FALLBACK 12GiB DGPU MINIMUM
TOTAL_VRAM_MIB=$(( 12 * 1024 ))
