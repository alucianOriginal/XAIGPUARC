log "🔷PATCH 11|12 STARTE QUANTISIERUNGS RUECKFALL SUCHE IN '${MODELS_DIR}'"

#|ALLE GGUF DATEIEN NACH GROESSE SORTIERT DURCHSUCHEN KLEINSTES PASSENDES NEHMEN
