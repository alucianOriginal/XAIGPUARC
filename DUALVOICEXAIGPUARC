log "🔷PATCH 12|12 SYCL LEISTUNGS PROFILER KOPFZEILENEINTRAEGE INITIALISIERUNG"

local PROFILER_SCRIPT="${BUILD_DIR}/XAIGPUARC_PROFILIER_PID.sh"
